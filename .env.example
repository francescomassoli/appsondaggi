# --- Supabase ---
# URL del progetto Supabase (Dashboard > Project Settings > API > Project URL)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Chiave pubblica "anon" (Dashboard > Project Settings > API > Project API keys > anon public)
# Usata SOLO per il login admin lato browser. Non legge dati sensibili.
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Chiave "service_role" (Dashboard > Project Settings > API > Project API keys > service_role)
# ATTENZIONE: segreta. Usata SOLO lato server (server actions / route handler).
# Non deve MAI comparire in codice client né con prefisso NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...
